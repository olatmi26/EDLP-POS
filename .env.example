APP_NAME="EDLP POS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Lagos

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=edlp_pos
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=pusher
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@edlpnigeria.com"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000

# CORS — add your frontend URL
FRONTEND_URL=http://localhost:5173
CDN_URL=

# Pusher / Laravel Echo — for real-time price updates + low-stock alerts
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# POS
POS_VAT_RATE=7.5
LOW_STOCK_THRESHOLD=5

# POS domain config (full set — matches config/pos.php)
POS_CURRENCY=NGN
POS_CURRENCY_SYMBOL=₦
POS_SESSION_AUTO_CLOSE_HOURS=12
POS_HOLD_EXPIRY_MINUTES=120
POS_SUGGESTION_CACHE_TTL=3600
POS_DASHBOARD_CACHE_TTL=300
POS_LEADERBOARD_CACHE_TTL=900
POS_MAX_PIN_ATTEMPTS=5
POS_MAX_LOGIN_ATTEMPTS=5
POS_SYNC_BATCH_SIZE=100
POS_RECEIPT_WIDTH_MM=80
POS_COMPANY_NAME="EDLP Nigeria Limited"
POS_COMPANY_ADDRESS="Nigeria"
POS_COMPANY_PHONE=
POS_COMPANY_EMAIL=
POS_COMPANY_WEBSITE=
POS_COMPANY_TAX_ID=
POS_RANK_GOLD=500000
POS_RANK_SILVER=100000
